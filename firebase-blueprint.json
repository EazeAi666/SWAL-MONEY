{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and financial summary",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "description": "User's email address" },
        "phone": { "type": "string", "description": "Format: 234..." },
        "balance": { "type": "number", "description": "Current wallet balance in NGN" },
        "kycLevel": { "type": "number", "description": "KYC verification level (0, 1, 2, 3)" },
        "kycStatus": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "deviceId": { "type": "string", "description": "Unique ID for device registration" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "balance", "phone"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner of the transaction" },
        "type": { "type": "string", "enum": ["credit", "debit"], "description": "Transaction type" },
        "category": { "type": "string", "description": "Category (e.g., transfer, airtime, deposit, savings)" },
        "amount": { "type": "number", "description": "Transaction amount" },
        "description": { "type": "string", "description": "Transaction details" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the transaction occurred" },
        "status": { "type": "string", "enum": ["success", "pending", "failed"], "description": "Transaction status" }
      },
      "required": ["uid", "type", "amount", "timestamp", "status"]
    },
    "Savings": {
      "title": "Savings",
      "description": "Savings account details",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "balance": { "type": "number" },
        "interestRate": { "type": "number" },
        "totalInterestEarned": { "type": "number" },
        "type": { "type": "string", "enum": ["owealth", "fixed", "target"] }
      },
      "required": ["uid", "balance", "interestRate"]
    },
    "Card": {
      "title": "Card",
      "description": "Virtual or physical card details",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "cardNumber": { "type": "string" },
        "expiry": { "type": "string" },
        "cvv": { "type": "string" },
        "type": { "type": "string", "enum": ["virtual", "physical"] },
        "status": { "type": "string", "enum": ["active", "blocked"] },
        "balance": { "type": "number" }
      },
      "required": ["uid", "cardNumber", "expiry", "cvv", "type", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and balance"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "History of all transactions"
    },
    "/savings/{userId}": {
      "schema": "Savings",
      "description": "User savings accounts"
    },
    "/cards/{cardId}": {
      "schema": "Card",
      "description": "User payment cards"
    }
  }
}
